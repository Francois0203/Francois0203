rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public, read-only portfolio content
    match /portfolio/{doc}      { allow read: if true; allow write: if false; }
    match /experience/{doc}     { allow read: if true; allow write: if false; }
    match /education/{doc}      { allow read: if true; allow write: if false; }
    match /projects/{doc}       { allow read: if true; allow write: if false; }
    match /githubProjects/{doc} { allow read: if true; allow write: if false; }

    // Contact form: visitors may submit; authenticated admin may read and delete
    match /contacts/{doc}       { allow create: if true; allow read, delete: if request.auth != null; allow update: if false; }

    // Everything else is denied by default
    match /{document=**}        { allow read, write: if false; }
  }
}
