rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allowlist — keep in sync with ADMIN_EMAILS in frontend/.env.local.
    // The env var only gates the UI; THIS is the real server-side enforcement.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
             'francoismeiring0203@gmail.com',
             'francoisme@shareforce.net'
           ];
    }

    // Public, read-only portfolio content — writable only by an admin.
    match /portfolio/{doc}      { allow read: if true; allow write: if isAdmin(); }
    match /experience/{doc}     { allow read: if true; allow write: if isAdmin(); }
    match /education/{doc}      { allow read: if true; allow write: if isAdmin(); }
    match /projects/{doc}       { allow read: if true; allow write: if isAdmin(); }
    match /githubProjects/{doc} { allow read: if true; allow write: if isAdmin(); }

    // Contact form: visitors may submit; admin may read and delete.
    match /contacts/{doc}       { allow create: if true; allow read, delete: if isAdmin(); allow update: if false; }

    // Everything else is denied by default.
    match /{document=**}        { allow read, write: if false; }
  }
}
